# Variables de entorno — copia este archivo a .env y ajusta los valores
#   copy .env.example .env

# ── Base de datos MySQL ──
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=          # ← OBLIGATORIO: pon aquí tu contraseña de MySQL
DB_NAME=bd_anim3d_saltos

# ── Puertos Flask ──
SALTO_PORT=5001
SENSOR_PORT=5000

# ── CORS (orígenes separados por coma, o * para permitir todos) ──
# Desarrollo local:
#   CORS_ORIGINS=https://localhost:8443,http://localhost:8080
# Producción (ajustar al dominio real):
#   CORS_ORIGINS=https://midominio.com,https://www.midominio.com
CORS_ORIGINS=*

# ── SSL / HTTPS (opcional) ──
# Directorio donde están cert.pem y key.pem.
# Si no se define, busca en <raíz_proyecto>/certs/
# SSL_CERT_DIR=/ruta/a/certificados
# SSL_CERT_FILE=cert.pem
# SSL_KEY_FILE=key.pem

# ── Límite de subida de vídeo (MB) ──
# MAX_UPLOAD_MB=100
