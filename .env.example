# Variables de entorno — copia este archivo a .env y ajusta los valores
#   copy .env.example .env

# ── Base de datos MySQL ──
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=          # ← OBLIGATORIO: pon aquí tu contraseña de MySQL
DB_NAME=bd_anim3d_saltos

# ── Puertos Flask ──
SALTO_PORT=5001
SENSOR_PORT=5000

# ── CORS (orígenes separados por coma) ──
CORS_ORIGINS=https://localhost:8443,https://127.0.0.1:8443,http://localhost:8080,http://127.0.0.1:8080
